# ===== DATABASE =====
POSTGRES_DB=integritybot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME_strong_password@db:5432/integritybot

# ===== REDIS =====
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_URL=redis://:CHANGE_ME_redis_password@redis:6379/0

# ===== TELEGRAM BOT =====
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_FROM_BOTFATHER
WEBHOOK_SECRET=CHANGE_ME_random_32char_string
# Production: to'liq HTTPS URL kiriting (webhook rejimi avtomatik yoqiladi)
# Lokal dev: bo'sh qoldiring (polling rejimi avtomatik ishlatiladi)
# Misol: WEBHOOK_URL=https://yourdomain.com/api/telegram/webhook
WEBHOOK_URL=
# Compliance admin group chat ID (negative number for groups)
ADMIN_CHAT_ID=-100123456789
# BOT_MODE: "auto" (tavsiya), "polling" (majburiy), "webhook" (majburiy)
# auto: WEBHOOK_URL https:// bo'lsa webhook, aks holda polling
# ⚠️  polling + webhook_url birga ISHLATMANG — Telegram 409 Conflict xatosi beradi
BOT_MODE=auto

# ===== SECURITY =====
SECRET_KEY=CHANGE_ME_very_long_random_secret_key_min_64_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Default admin paroli (birinchi ishga tushirishda yaratiladi)
# ⚠️  MAJBURIY: CHANGE_ME ni kuchli parol bilan almashtiring!
# Talab: kamida 8 belgi, 1 ta katta harf, 1 ta raqam
# Misol yaratish: python -c "import secrets; print(secrets.token_urlsafe(16))"
ADMIN_DEFAULT_PASSWORD=CHANGE_ME_strong_password_min_16_chars

# AES-256 encryption key (32 bytes, base64 encoded)
# Generate: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_KEY=CHANGE_ME_base64_encoded_32byte_key

# Ixtiyoriy: alohida kalitlar (xavfsizroq — kalit izolyatsiyasi)
# Bo'sh qoldirilsa — ENCRYPTION_KEY dan foydalaniladi (backwards compatibility)
# Tavsiya: production muhitida alohida kalitlar sozlang
# CASE_ENCRYPTION_KEY=    # Case.description_encrypted uchun
# COMMENT_ENCRYPTION_KEY= # CaseComment.content_encrypted uchun

# ===== EMAIL (SMTP) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=compliance@company.uz
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@company.uz
SMTP_TLS=true

# ===== STORAGE =====
# "local" yoki "s3"
STORAGE_TYPE=local
UPLOADS_DIR=/app/uploads
MAX_FILE_SIZE_MB=20

# ─── AWS S3 (STORAGE_TYPE=s3 bo'lganda) ─────────────────────────────────────
# AWS credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=integrity-bot-files
AWS_REGION=us-east-1

# S3-compatible servislar uchun endpoint (ixtiyoriy):
#   MinIO:         S3_ENDPOINT_URL=http://minio:9000
#   Yandex Cloud:  S3_ENDPOINT_URL=https://storage.yandexcloud.net
#   DigitalOcean:  S3_ENDPOINT_URL=https://nyc3.digitaloceanspaces.com
S3_ENDPOINT_URL=

# CDN orqali to'g'ridan-to'g'ri URL (ixtiyoriy, presigned URL o'rniga):
#   CloudFront:    S3_PUBLIC_BASE_URL=https://d1234.cloudfront.net
S3_PUBLIC_BASE_URL=

# ===== APPLICATION =====
ENVIRONMENT=production
DEBUG=false
ALLOWED_ORIGINS=https://yourdomain.com
APP_NAME=IntegrityBot
COMPANY_NAME=Your Company Name

# ===== SECRETS BACKEND =====
# "env" (default, development) | "vault" | "awskms"
SECRETS_BACKEND=env

# HashiCorp Vault (SECRETS_BACKEND=vault bo'lganda)
VAULT_ADDR=http://vault:8200
# Token auth:
VAULT_TOKEN=
# YOki AppRole auth (token o'rniga):
VAULT_ROLE_ID=
VAULT_SECRET_ID=
VAULT_SECRET_PATH=secret/data/integritybot

# AWS Secrets Manager (SECRETS_BACKEND=awskms bo'lganda)
# AWS_SECRET_NAME=integritybot/prod
# (AWS_REGION va AWS_ACCESS_KEY_ID yuqorida belgilangan)

# Vault'da saqlanadigan kalit nomlar (JSON format):
# {
#   "SECRET_KEY": "...",
#   "ENCRYPTION_KEY": "...",
#   "TELEGRAM_BOT_TOKEN": "...",
#   "POSTGRES_PASSWORD": "...",
#   "REDIS_PASSWORD": "..."
# }

# ===== JIRA INTEGRATSIYA (opsional) =====
# Kritik/yuqori priorityli murojaatlarda avtomatik tiket yaratadi
# Bo'sh qoldirilsa — integratsiya o'chiriladi
JIRA_URL=
JIRA_TOKEN=
JIRA_USER_EMAIL=          # Atlassian Cloud uchun (Server da bo'sh qoldiring)
JIRA_PROJECT_KEY=COMP
JIRA_ISSUE_TYPE=Task
# Qaysi prioritydan tiket ochsin: critical | high | all
JIRA_MIN_PRIORITY=critical

# ===== REDMINE INTEGRATSIYA (opsional, Jira alternativasi) =====
REDMINE_URL=
REDMINE_API_KEY=
REDMINE_PROJECT_ID=

# ===== SIEM / LOG FORWARDING (opsional) =====
# Splunk, Elasticsearch, Graylog, yoki Webhook ga loglar yuboriladi
# Ishlatish: docker compose --profile siem up -d  (Filebeat bilan)
# Backend to'g'ridan: SIEM_ENABLED=true
SIEM_ENABLED=false
# splunk | elastic | graylog | webhook
SIEM_BACKEND=splunk
# Splunk HEC:  https://splunk.company.uz:8088/services/collector
# Elastic:     https://elastic.company.uz:9200
# Graylog:     https://graylog.company.uz:12201
SIEM_URL=
# Splunk HEC token / Elastic API key / Bearer token
SIEM_TOKEN=
# Splunk index / Elastic index
SIEM_INDEX=integritybot-logs
# SSL sertifikatini tekshirish (false — self-signed uchun)
SIEM_VERIFY_SSL=true
# Log formati: json (production) | text (development)
SIEM_LOG_FORMAT=json

# ── Filebeat → Elasticsearch (docker compose --profile siem) ──────────────
ELASTICSEARCH_ENABLED=false
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_TOKEN=
ELASTIC_USER=
ELASTIC_PASSWORD=
ELASTIC_SSL_VERIFY=full
# ⚠️  PRODUCTION DA TRUE QILING!
# False bo'lsa — yuklangan fayllar skanlanmaydi (xavfli)
# ClamAV ishga tushirish: docker compose --profile production up -d clamav
CLAMAV_ENABLED=false
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# ===== MONITORING (docker compose --profile monitoring up) =====
GRAFANA_PASSWORD=CHANGE_ME_grafana_password

# ===== LDAP / ACTIVE DIRECTORY SSO (opsional) =====
# Korporativ login — xodimlar AD/LDAP parollari bilan kiradi
# Bo'sh qoldirilsa — faqat lokal autentifikatsiya ishlaydi
LDAP_ENABLED=false
# ldap://dc.yourcompany.uz  yoki  ldaps://dc.yourcompany.uz (SSL uchun)
LDAP_URL=
# AD domain (user@domain.uz format uchun)
LDAP_DOMAIN=yourcompany.uz
# Qidiruv uchun base DN
LDAP_BASE_DN=DC=yourcompany,DC=uz
# Service account (read-only, foydalanuvchilarni qidirish uchun)
LDAP_BIND_DN=CN=ldap-reader,OU=ServiceAccounts,DC=yourcompany,DC=uz
LDAP_BIND_PASSWORD=
# Foydalanuvchi qidiruv filtri (OpenLDAP: (uid={username}))
LDAP_USER_FILTER=(sAMAccountName={username})
# Roli aniqlaydigan guruhlar (bo'sh = default viewer roli)
LDAP_GROUP_ADMIN=CN=IntegrityBot-Admins,OU=Groups,DC=yourcompany,DC=uz
LDAP_GROUP_INVESTIGATOR=CN=IntegrityBot-Investigators,OU=Groups,DC=yourcompany,DC=uz
# SSL sozlamalari
LDAP_USE_SSL=false
LDAP_TLS_VALIDATE=true

# ===== FRONTEND =====
VITE_API_URL=https://yourdomain.com/api
