# ===== DATABASE =====
POSTGRES_DB=integritybot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME_strong_password@db:5432/integritybot

# ===== REDIS =====
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_URL=redis://:CHANGE_ME_redis_password@redis:6379/0

# ===== TELEGRAM BOT =====
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_FROM_BOTFATHER
WEBHOOK_SECRET=CHANGE_ME_random_32char_string
WEBHOOK_URL=https://yourdomain.com/api/telegram/webhook
# Compliance admin group chat ID (negative number for groups)
ADMIN_CHAT_ID=-100123456789

# ===== SECURITY =====
SECRET_KEY=CHANGE_ME_very_long_random_secret_key_min_64_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AES-256 encryption key (32 bytes, base64 encoded)
# Generate: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_KEY=CHANGE_ME_base64_encoded_32byte_key

# ===== EMAIL (SMTP) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=compliance@company.uz
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@company.uz
SMTP_TLS=true

# ===== STORAGE =====
# "local" yoki "s3"
STORAGE_TYPE=local
UPLOADS_DIR=/app/uploads
MAX_FILE_SIZE_MB=20

# ─── AWS S3 (STORAGE_TYPE=s3 bo'lganda) ─────────────────────────────────────
# AWS credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=integrity-bot-files
AWS_REGION=us-east-1

# S3-compatible servislar uchun endpoint (ixtiyoriy):
#   MinIO:         S3_ENDPOINT_URL=http://minio:9000
#   Yandex Cloud:  S3_ENDPOINT_URL=https://storage.yandexcloud.net
#   DigitalOcean:  S3_ENDPOINT_URL=https://nyc3.digitaloceanspaces.com
S3_ENDPOINT_URL=

# CDN orqali to'g'ridan-to'g'ri URL (ixtiyoriy, presigned URL o'rniga):
#   CloudFront:    S3_PUBLIC_BASE_URL=https://d1234.cloudfront.net
S3_PUBLIC_BASE_URL=

# ===== APPLICATION =====
ENVIRONMENT=production
DEBUG=false
ALLOWED_ORIGINS=https://yourdomain.com
APP_NAME=IntegrityBot
COMPANY_NAME=Your Company Name

# ===== SECRETS BACKEND =====
# "env" (default, development) | "vault" | "awskms"
SECRETS_BACKEND=env

# HashiCorp Vault (SECRETS_BACKEND=vault bo'lganda)
VAULT_ADDR=http://vault:8200
# Token auth:
VAULT_TOKEN=
# YOki AppRole auth (token o'rniga):
VAULT_ROLE_ID=
VAULT_SECRET_ID=
VAULT_SECRET_PATH=secret/data/integritybot

# AWS Secrets Manager (SECRETS_BACKEND=awskms bo'lganda)
# AWS_SECRET_NAME=integritybot/prod
# (AWS_REGION va AWS_ACCESS_KEY_ID yuqorida belgilangan)

# Vault'da saqlanadigan kalit nomlar (JSON format):
# {
#   "SECRET_KEY": "...",
#   "ENCRYPTION_KEY": "...",
#   "TELEGRAM_BOT_TOKEN": "...",
#   "POSTGRES_PASSWORD": "...",
#   "REDIS_PASSWORD": "..."
# }

# ===== ANTIVIRUS (ClamAV) =====
# True qilish uchun docker-compose da clamav service ishlashi kerak
CLAMAV_ENABLED=false
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# ===== MONITORING (docker compose --profile monitoring up) =====
GRAFANA_PASSWORD=CHANGE_ME_grafana_password

# ===== FRONTEND =====
VITE_API_URL=https://yourdomain.com/api
