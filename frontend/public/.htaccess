Options -MultiViews
RewriteEngine On

# /api/ so'rovlari Python backendga ketadi (cPanel Python Selector tomonidan boshqariladi)
# Bu qatorni qo'shmang — nginx yoki Passenger o'zi hal qiladi

# Statik fayllar bo'lsa — to'g'ridan xizmat ko'rsatish
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Papka bo'lsa — to'g'ridan xizmat ko'rsatish
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Qolgan hamma so'rov (Vue Router) → index.html
RewriteRule ^ index.html [QSA,L]

# Cache sozlamalari
<FilesMatch "\.(js|css|woff|woff2|ttf|svg|png|jpg|jpeg|gif|ico|webp)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

<FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
</FilesMatch>
